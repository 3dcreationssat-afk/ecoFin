DATABASE_URL="file:./dev.db"

# Plaid is optional. Keep real values in .env.local only.
PLAID_ENV="sandbox"
PLAID_CLIENT_ID=""
PLAID_SECRET=""
# Base64-encoded 32 random bytes. Store separately from database backups.
PLAID_TOKEN_ENCRYPTION_KEY=""
# Optional in Sandbox; production OAuth redirect URIs must use HTTPS.
PLAID_REDIRECT_URI=""
# Optional for local-only manual synchronization.
PLAID_WEBHOOK_URL=""
